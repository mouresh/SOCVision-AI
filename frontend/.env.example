# =============================================================================
# SOCVision AI — Environment Configuration Template
# Copy to .env and fill in values.  Never commit .env to version control.
# =============================================================================

# ── Runtime ───────────────────────────────────────────────────────────────────
NODE_ENV=development           # development | test | production
PORT=8080
HOST=0.0.0.0

# ── API ───────────────────────────────────────────────────────────────────────
API_VERSION=v1
API_PREFIX=/api

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=socvision
DB_USER=socvision_app
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_SSL=false                   # false | true | require
DB_POOL_MIN=2
DB_POOL_MAX=20
DB_POOL_IDLE_TIMEOUT_MS=30000
DB_POOL_CONNECTION_TIMEOUT_MS=5000
DB_STATEMENT_TIMEOUT_MS=30000

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_AT_LEAST_32_CHARS_RANDOM_STRING
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=CHANGE_ME_AT_LEAST_32_CHARS_DIFFERENT_RANDOM_STRING
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins, or * for all
CORS_ORIGIN=http://localhost:3000
CORS_CREDENTIALS=true

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000    # 15 minutes in ms
RATE_LIMIT_MAX_REQUESTS=500    # per window per IP (general)
RATE_LIMIT_AUTH_MAX=10         # per window per IP (auth endpoints)

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info                 # error | warn | info | http | verbose | debug
LOG_FORMAT=pretty              # json | pretty  (use json in production)
LOG_DIR=logs

# ── Redis (optional) ──────────────────────────────────────────────────────────
# REDIS_URL=redis://localhost:6379

# ── Splunk Integration (optional) ────────────────────────────────────────────
# SPLUNK_HEC_URL=https://splunk.internal:8088
# SPLUNK_HEC_TOKEN=

# ── Wazuh Integration (optional) ─────────────────────────────────────────────
# WAZUH_API_URL=https://wazuh-manager.internal:55000
# WAZUH_API_USER=wazuh-api
# WAZUH_API_PASSWORD=

# ── Feature Flags ─────────────────────────────────────────────────────────────
ENABLE_SWAGGER=true
ENABLE_METRICS=false
